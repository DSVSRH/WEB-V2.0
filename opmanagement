}


/* PART 07-AUTHENTICATION LOGIC */
async function doLogin() { const i = document.getElementById('logId').value.trim().toUpperCase(); const p = document.getElementById('logPass').value; const e = document.getElementById('err'); if(!i||!p){e.innerText="Please fill all fields.";e.classList.remove('hidden');return;} setLoginLoading(true); e.classList.add('hidden'); try { const r=await fetch(`${URL_LOGIN_FETCH}?action=login&id=${i}&pass=${p}`); const d=await r.json(); if(d.success){ user=d.userProfile; document.getElementById('loginPanel').classList.add('hidden'); document.getElementById('userBar').classList.remove('hidden'); document.getElementById('userBar').classList.add('flex'); document.getElementById('dashboard').classList.remove('hidden'); document.getElementById('SVSR_REGISTRATION_MODULE').classList.remove('hidden'); document.getElementById('userNameDisp').innerText = `Operator: ${user.fullName}`; const bh = document.getElementById('branchHeading'); if(user.branchSite.toLowerCase() === 'main-1') bh.innerText = "BONE EYE TRAUMA CARE HOSPITAL"; else if(user.branchSite.toLowerCase() === 'main-2') bh.innerText = "DR. S VENKATA SUBBA REDDY HOSPITAL"; else bh.innerText = user.branchSite.toUpperCase(); applyDefaultInputs(); loadData(); } else { e.innerText=d.message; e.classList.remove('hidden'); } } catch(x){showToast("Login Service Error.");} finally {setLoginLoading(false);} }


/* PART 08-DATA FETCHING AND RENDERING */
async function loadData(isRefresh = false) { 
  const icon = document.getElementById('reloadIcon'); 
  if(isRefresh && icon) {
    icon.classList.add('opacity-50'); 
  } 
  try { 
    const r=await fetch(`${URL_LOGIN_FETCH}?action=fetch&branch=${user.branchSite}`); 
    const d=await r.json(); 
    globalPatientList = d; 
    renderT(d); 
    if(isRefresh) showToast("DATA REFRESHED"); 
  } catch(x){
    console.error(x);
  } finally { 
    if(isRefresh && icon) {
      icon.classList.remove('opacity-50'); 
    } 
  } 
}

// Background dynamic sync interval: fetches data silently from the spreadsheet every 5 seconds
setInterval(() => {
  if (user && user.branchSite) {
    loadData(false);
  }
}, 5000);

function renderT(list) { const mb=document.getElementById('morningPaidBody'), eb=document.getElementById('eveningPaidBody'), tb=document.getElementById('todayBody'), fb=document.getElementById('futureRegisteredBody'); mb.innerHTML=''; eb.innerHTML=''; tb.innerHTML=''; fb.innerHTML=''; let mi=1, ei=1, ti=1, fi=1; let morningSum = 0; let eveningSum = 0; const todayStr = formatDate(new Date()); list.forEach((p)=>{ const isP=p.opdAmountPaid!==undefined && p.opdAmountPaid!==null && String(p.opdAmountPaid).trim()!=="" && Number(p.opdAmountPaid)>0; const parsedDate = parseSheetDate(p.entryDate); const recordDate = parsedDate ? formatDate(parsedDate) : todayStr; const rowContent = `<td>${recordDate}</td><td class="font-bold text-blue-900">${p.patientId}</td><td class="font-bold text-gray-900">${p.tokenNumber}</td><td class="font-bold uppercase text-gray-800">${p.patientName}</td><td class="text-gray-500">${p.phoneNumber}</td><td class="text-gray-400 font-bold">${p.patientAge}/${p.patientGender}</td><td class="text-gray-500">${p.villageName}</td><td class="font-bold text-blue-700">${p.doctorId}</td>`; if(recordDate !== todayStr) { fb.innerHTML += `<tr class="hover:bg-gray-50 transition"><td>${fi++}</td><td>${recordDate}</td><td class="font-bold text-blue-900">${p.patientId}</td><td class="font-bold text-gray-900">${p.tokenNumber}</td><td class="font-bold uppercase text-gray-800">${p.patientName}</td><td class="text-gray-500">${p.phoneNumber}</td><td class="text-gray-400 font-bold">${p.patientAge}/${p.patientGender}</td><td class="text-gray-500">${p.villageName}</td><td class="font-bold text-blue-700">${p.doctorId}</td><td class="font-bold text-green-700">${p.opdAmountPaid || '0'}</td><td class="no-print"><button id="btnDel-${p.serialNumber}" onclick="askMove('${p.serialNumber}', false)" class="text-red-500 hover:text-red-700 transition flex justify-center items-center w-full"><i id="icoDel-${p.serialNumber}" class="fas fa-trash-alt"></i><i id="spinDel-${p.serialNumber}" class="fas fa-circle-notch fa-spin hidden"></i></button></td></tr>`; } else { if(isP) { const dt = new Date(p.entryTime); const hour = dt.getHours(); const paidRow = `<tr class="hover:bg-gray-50 transition"><td>${hour < 15 ? mi++ : ei++}</td>${rowContent}<td class="font-bold text-green-700 text-center">${p.opdAmountPaid}</td><td class="no-print"><button onclick='printOpSlip(${JSON.stringify(p)})' class="text-blue-600 hover:text-black transition flex justify-center items-center w-full"><i class="fas fa-print mr-1"></i> OP PRINT</button></td><td class="no-print"><button onclick='printPaymentReceipt(${JSON.stringify(p)})' class="text-emerald-600 hover:text-black transition flex justify-center items-center w-full"><i class="fas fa-file-invoice mr-1"></i> RECEIPT PRINT</button></td></tr>`; if(hour < 15){ mb.innerHTML += paidRow; morningSum += Number(p.opdAmountPaid); } else { eb.innerHTML += paidRow; eveningSum += Number(p.opdAmountPaid); } } else { tb.innerHTML += `<tr class="hover:bg-gray-50 transition"><td>${ti++}</td><td>${recordDate}</td><td class="font-bold text-blue-900">${p.patientId}</td><td class="font-bold text-gray-900">${p.tokenNumber}</td><td class="font-bold uppercase text-gray-800">${p.patientName}</td><td class="text-gray-500">${p.phoneNumber}</td><td class="text-gray-400 font-bold">${p.patientAge}/${p.patientGender}</td><td class="text-gray-500">${p.villageName}</td><td class="font-bold text-blue-700">${p.doctorId}</td><td><div class="flex items-center justify-center space-x-1"><input type="number" id="amt-${p.serialNumber}" value="${p.opdAmountPaid||''}" class="w-14 border rounded px-1.5 py-0.5 text-[10px] outline-none font-bold focus:border-blue-500"><button id="btnVer-${p.serialNumber}" onclick="showModal('update', '${p.serialNumber}')" class="bg-blue-600 text-white px-2 py-0.5 rounded text-[9px] font-bold hover:bg-black transition flex items-center justify-center min-w-[45px]"><span id="txtVer-${p.serialNumber}">VERIFY</span><i id="spinVer-${p.serialNumber}" class="fas fa-circle-notch fa-spin hidden"></i></button></div></td><td class="no-print"><button id="btnDel-${p.serialNumber}" onclick="askMove('${p.serialNumber}', false)" class="text-red-500 hover:text-red-700 transition flex justify-center items-center w-full"><i id="icoDel-${p.serialNumber}" class="fas fa-trash-alt"></i><i id="spinDel-${p.serialNumber}" class="fas fa-circle-notch fa-spin hidden"></i></button></td></tr>`; } } }); document.getElementById('todayCounter').innerText = `Pending Members: ${ti - 1}`; document.getElementById('morningCounter').innerText = `Paid: ${mi - 1} | Total: ₹${morningSum}`; document.getElementById('eveningCounter').innerText = `Paid: ${ei - 1} | Total: ₹${eveningSum}`; reorderOPDSections(); }
function reorderOPDSections() { const hr = new Date().getHours(); const container = document.getElementById('opdPaidContainer'); const morning = document.getElementById('morningCard'); const evening = document.getElementById('eveningCard'); if (hr >= 15) { container.insertBefore(evening, morning); } else { container.insertBefore(morning, evening); } }


/* PART 09-MODAL AND PRINTING PROCEDURES */
function askMove(s, isFromPaid = false) { activeSNo = s; activeAction = 'delete'; showModal('delete', s); }
function showModal(type, sNo) { activeSNo = sNo; activeAction = type; const m = document.getElementById('confirmModal'); const icon = document.getElementById('modalIconBox'); const title = document.getElementById('modalTitle'); const msg = document.getElementById('modalMsg'); const btn = document.getElementById('finalConfirm'); if(type === 'update') { const a = document.getElementById(`amt-${sNo}`).value; icon.className = "w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 bg-blue-50 text-blue-600"; icon.innerHTML = '<i class="fas fa-check-circle text-xl"></i>'; title.innerText = "Confirm Update"; msg.innerText = `Are you sure you want to verify payment of ₹${a}?`; btn.className = "flex-1 py-2.5 bg-blue-600 text-white rounded-xl text-[10px] font-bold hover:bg-blue-700 transition shadow-lg"; } else { icon.className = "w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 bg-red-50 text-red-500"; icon.innerHTML = '<i class="fas fa-trash-alt text-xl"></i>'; title.innerText = "Confirm Delete"; msg.innerText = "Are you sure you want to delete this record?"; btn.className = "flex-1 py-2.5 bg-red-600 text-white rounded-xl text-[10px] font-bold hover:bg-red-700 shadow-lg transition shadow-md"; } m.classList.remove('hidden'); }
function printOpSlip(p) { const now = new Date(); const dayName = now.toLocaleDateString('en-US', { weekday: 'long' }); const fullDate = now.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }); let branchName = user.branchSite.toLowerCase() === 'main-1' ? "BONE EYE TRAUMA CARE HOSPITAL" : (user.branchSite.toLowerCase() === 'main-2' ? "DR. S VENKATA SUBBA REDDY HOSPITAL" : user.branchSite.toUpperCase()); const setElVal = (id, val) => { const el = document.getElementById(id); if (el) el.innerText = val; }; setElVal('prHospitalName', "DR. S. VENKATA SUBBA REDDY MULTISPECIALTY HOSPITAL"); setElVal('prBranchName', branchName); setElVal('prDateDay', `${dayName}, ${fullDate}`); setElVal('prPID', p.patientId); setElVal('prToken', String(p.tokenNumber).replace(/^[A-Za-z]+/, '')); setElVal('prName', p.patientName); setElVal('prAgeGen', `${p.patientAge} / ${p.patientGender}`); setElVal('rprVillage', p.villageName); setElVal('rprVillage2', p.villageName); setElVal('prDocName', p.doctorName); setElVal('prDocRole', DOC_INFO[p.doctorId]?.enRole || "Consultant"); const docInfo = DOC_INFO[p.doctorId]; if (docInfo) { document.getElementById('docEnName').innerText = docInfo.enName; document.getElementById('docEnRole').innerText = docInfo.enRole; document.getElementById('docEnReg').innerText = docInfo.enReg; document.getElementById('docTeName').innerText = docInfo.teName; document.getElementById('docTeRole').innerText = docInfo.teRole; document.getElementById('docTeReg').innerText = docInfo.teReg; } document.body.classList.add('print-op-mode'); window.print(); document.body.classList.remove('print-op-mode'); }
function printPaymentReceipt(p) { const cleanToken = String(p.tokenNumber).replace(/^[A-Za-z]+/, '').padStart(2, '0'); document.getElementById('rcptTokenBig').innerText = cleanToken; document.getElementById('rcptName').innerText = p.patientName; document.getElementById('rcptVillage').innerText = p.villageName; document.getElementById('rcptAgeGen').innerText = `${p.patientAge} / ${p.patientGender}`; document.getElementById('rcptPID').innerText = p.patientId; document.getElementById('rcptAmt').innerText = p.opdAmountPaid; document.body.classList.add('print-receipt-mode'); window.print(); document.body.classList.remove('print-receipt-mode'); }


/* PART 10-FINAL EVENT HANDLERS AND SUBMISSION */
document.getElementById('finalConfirm').onclick = async () => { const s = activeSNo; const action = activeAction; if(!s) return; closeModal(); if(action === 'update') { const a = document.getElementById(`amt-${s}`).value; if(!a) return; const localRec = globalPatientList.find(x => x.serialNumber === s); if (localRec) { localRec.opdAmountPaid = a; localRec.entryTime = new Date().toISOString(); } renderT(globalPatientList); showToast("PAYMENT UPDATING..."); try { await fetch(`${URL_MOD_EXPENSE_ARCHIVE}?action=update&sNo=${s}&amt=${a}`); await loadData(); showToast("PAYMENT UPDATED ON SHEET"); } catch(x){showToast("Update Sync Failed");} } else { const localIdx = globalPatientList.findIndex(x => x.serialNumber === s); if (localIdx !== -1) { globalPatientList.splice(localIdx, 1); } renderT(globalPatientList); showToast("REMOVING RECORD..."); try { await fetch(`${URL_MOD_EXPENSE_ARCHIVE}?action=archive&sNo=${s}`); await loadData(); showToast("RECORD DELETED FROM SHEET"); } catch(x){showToast("Deletion Sync Failed");} } };
function verifyPatient() { const pid = document.getElementById('pidInput').value.trim().toUpperCase(); if (!pid) { showToast("PLEASE ENTER PATIENT ID"); return; } const record = globalPatientList.find(p => p.patientId === pid); if (!record) { showToast("PATIENT NOT FOUND"); return; } activeModRecord = record; activeModRecord.originalAmount = record.opdAmountPaid || ''; const detailsDiv = document.getElementById('modificationDetails'); const spans = detailsDiv.querySelectorAll('span.text-gray-600'); spans[0].innerHTML = `<input type="text" id="modName" value="${record.patientName}" class="w-full text-center bg-transparent font-bold text-gray-800 outline-none">`; spans[1].innerHTML = `<input type="text" id="modVillage" value="${record.villageName}" class="w-full text-center bg-transparent font-bold text-gray-800 outline-none">`; spans[2].innerHTML = `<input type="text" id="modPhone" value="${record.phoneNumber}" class="w-full text-center bg-transparent font-bold text-gray-800 outline-none">`; spans[3].innerHTML = `<input type="text" id="modDocId" value="${record.doctorId}" class="w-full text-center bg-transparent font-bold text-gray-800 outline-none">`; spans[4].innerHTML = `<input type="text" id="modAgeGen" value="${record.patientAge}/${record.patientGender}" class="w-full text-center bg-transparent font-bold text-gray-800 outline-none">`; spans[5].innerHTML = `<input type="number" id="modAmount" value="${record.opdAmountPaid || ''}" class="w-full text-center bg-transparent font-bold text-gray-800 outline-none">`; showToast("DETAILS LOADED SUCCESSFUL"); }
async function submitModification() { if (!activeModRecord) { showToast("VERIFY A PATIENT FIRST"); return; } const sNo = activeModRecord.serialNumber; const name = document.getElementById('modName').value.trim(); const village = document.getElementById('modVillage').value.trim(); const phone = document.getElementById('modPhone').value.trim(); const docId = document.getElementById('modDocId').value.trim(); const ageGen = document.getElementById('modAgeGen').value.trim().split('/'); const age = ageGen[0] || activeModRecord.patientAge; const gender = ageGen[1] || activeModRecord.patientGender; const amount = document.getElementById('modAmount').value.trim(); const reason = document.getElementById('modReason').value.trim(); if (String(amount) !== String(activeModRecord.originalAmount)) { if (!reason) { showToast("REASON IS MANDATORY TO MODIFY AMOUNT"); document.getElementById('modReason').focus(); return; } } const localRec = globalPatientList.find(x => x.serialNumber === sNo); if (localRec) { localRec.patientName = name; localRec.villageName = village; localRec.phoneNumber = phone; localRec.doctorId = docId; localRec.patientAge = age; localRec.patientGender = gender; localRec.opdAmountPaid = amount; } renderT(globalPatientList); showToast("SAVING MODIFICATIONS..."); try { const modData = new FormData(); modData.append("action", "modify");
        modData.append("sNo", sNo);
        modData.append("patientId", activeModRecord.patientId);
        modData.append("patientName", name);
        modData.append("village", village);
        modData.append("phoneNumber", phone);
        modData.append("doctorId", docId);
        modData.append("age", age);
        modData.append("gender", gender);
        modData.append("amount", amount);
        modData.append("reason", reason);
        await fetch(URL_MOD_EXPENSE_ARCHIVE, { method: 'POST', body: modData });
        await loadData();
        showToast("RECORD MODIFICATION SAVED");
        document.getElementById('modReason').value = '';
      } catch(x) {
        showToast("Failed to sync modifications");
      } }
async function submitExpense() { const amt = document.getElementById('expenseAmount').value.trim(); const reason = document.getElementById('expenseReason').value.trim(); if (!amt || !reason) { showToast("PLEASE FILL AMOUNT AND REASON"); return; } showToast("SUBMITTING EXPENSE..."); try { const expData = new FormData(); expData.append("action", "expense"); expData.append("amount", amt); expData.append("reason", reason); await fetch(URL_MOD_EXPENSE_ARCHIVE, { method: 'POST', body: expData }); showToast("EXPENSE RECORDED SUCCESSFULLY"); document.getElementById('expenseAmount').value = ''; document.getElementById('expenseReason').value = ''; } catch(x) { showToast("Failed to save expense"); } }
function handleTitleCase(el) { el.value = el.value.toLowerCase().split(' ').map(s => s.charAt(0).toUpperCase() + s.substring(1)).join(' '); }
function toggleDropdown(e, id) { e.stopPropagation(); document.querySelectorAll('.dropdown-options').forEach(d => { if(d.id !== id) d.classList.remove('show'); }); document.getElementById(id).classList.toggle('show'); }
function selectDrop(hiddenId, val, label, dropId) { document.getElementById(hiddenId).value = val; document.getElementById(hiddenId + 'Display').innerText = label; document.getElementById(dropId).classList.remove('show'); }
function SET_DEFAULT_TIMESTAMP() { const N = new Date(); document.getElementById('formDate').value = N.toISOString().split('T')[0]; }
function RESET_REGISTRATION_INTERFACE() { location.reload(); }
function PROCEDURE_INITIATE_TOKEN_DOWNLOAD() { const btn = document.getElementById('dlBtn'); btn.innerText = "CAPTURING..."; btn.disabled = true; setTimeout(() => { const ticket = document.getElementById('ticketCapture'); html2canvas(ticket, { scale: 3, backgroundColor: '#ffffff' }).then(canvas => { const link = document.createElement('a'); link.download = 'SVSR_Hospital_Token.png'; link.href = canvas.toDataURL(); link.click(); btn.innerText = "Print"; btn.disabled = false; }); }, 800); }
function PROCEDURE_INITIATE_TOKEN_SHARE() { const btn = document.getElementById('shBtn'); btn.innerText = "SHARING..."; btn.disabled = true; setTimeout(() => { const ticket = document.getElementById('ticketCapture'); html2canvas(ticket, { scale: 3 }).then(canvas => { canvas.toBlob(blob => { if (navigator.share && blob) { const file = new File([blob], 'SVSR_Token.png', { type: 'image/png' }); navigator.share({ files: [file], title: 'Patient Entry Token' }).then(() => { btn.innerText = "Share"; btn.disabled = false; }).catch(() => { fallbackCopyText(); }); } else { fallbackCopyText(); } }); }); }, 800); function fallbackCopyText() { const pName = document.getElementById('resName').innerText; const tokenNo = document.getElementById('resToken').innerText; const shareText = `SVSR Hospital Token No: ${tokenNo} for Patient: ${pName}`; const el = document.createElement('textarea'); el.value = shareText; document.body.appendChild(el); el.select(); document.execCommand('copy'); document.body.removeChild(el); showToast("Token info copied to clipboard! Share details anywhere."); btn.innerText = "Share"; btn.disabled = false; } }
SET_DEFAULT_TIMESTAMP();
document.getElementById("tokenForm").addEventListener("submit", async function(e) { e.preventDefault(); const doctorVal = document.getElementById("doctor").value; if (!doctorVal) { document.getElementById('statusMessage').innerText = "Please select a Clinical Department."; return; } document.getElementById('loadingOverlay').style.display = 'flex'; const patName = document.getElementById("patientName").value; const patAge = document.getElementById("age").value; const patGen = document.getElementById("gender").value; const patPhone = document.getElementById("phoneNumber").value; const patVillage = document.getElementById("village").value; const patAmount = document.getElementById("amount").value; const tempSNo = "TEMP-" + Date.now(); const localNewPatient = { serialNumber: tempSNo, patientId: "PID-NEW", tokenNumber: "WAIT", patientName: patName, phoneNumber: patPhone, patientAge: patAge, patientGender: patGen, villageName: patVillage, doctorId: doctorVal, doctorName: DOC_INFO[doctorVal]?.enName || "Consultant", entryDate: formatDate(new Date()), entryTime: new Date().toISOString(), opdAmountPaid: patAmount }; globalPatientList.push(localNewPatient); renderT(globalPatientList); const formData = new FormData(); formData.append("doctor", doctorVal); formData.append("patientName", patName); formData.append("age", patAge); formData.append("gender", patGen); formData.append("phoneNumber", patPhone); formData.append("village", patVillage); formData.append("amount", patAmount); try { const response = await fetch(URL_REGISTRATION, { method: 'POST', body: formData }); const data = await response.json(); if(data.result === "success") { const idx = globalPatientList.findIndex(x => x.serialNumber === tempSNo); if (idx !== -1) { globalPatientList[idx].patientId = data.patientId || "PID-VSR"; globalPatientList[idx].tokenNumber = data.tokenNumber || "T01"; } renderT(globalPatientList); document.getElementById('tokenForm').classList.add('hidden'); document.getElementById('headerSection').classList.add('hidden'); const inlineSuccess = document.getElementById('inlineSuccessMessage'); inlineSuccess.classList.remove('hidden'); inlineSuccess.classList.add('flex'); setTimeout(() => { inlineSuccess.classList.add('hidden'); inlineSuccess.classList.remove('flex'); document.getElementById('tokenForm').classList.remove('hidden'); document.getElementById('headerSection').classList.remove('hidden'); document.getElementById('tokenForm').reset();
            applyDefaultInputs(); // Re-apply the default inputs (Female / OBG Gynaecology) after submission reset
            loadData(); }, 2000); } else { document.getElementById('statusMessage').innerText = "Error: " + data.message; } } catch(err) { document.getElementById('statusMessage').innerText = "Submission failed. Check connection."; } finally { document.getElementById('loadingOverlay').style.display = 'none'; } });
</script>
